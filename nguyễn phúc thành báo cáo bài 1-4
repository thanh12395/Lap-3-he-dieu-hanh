#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <signal.h>
#include <sys/wait.h>

pid_t child_pid; /* PID cua tien trinh con chay vim, dung global de
                     ham xu ly signal co the truy cap duoc */

/* Ham xu ly tin hieu SIGINT (Ctrl+C) */
void handle_sigint(int sig) {
    /* (c) Tat vim editor: gui tin hieu SIGTERM cho tien trinh con
       dang chay vim de yeu cau no ket thuc                         */
    kill(child_pid, SIGTERM);
    wait(NULL); /* cho vim ket thuc hoan toan, tranh zombie */

    /* (d) In ra dong thong bao khi nguoi dung nhan Ctrl+C */
    printf("You are pressed CTRL+C! Goodbye!\n");
    exit(0);
}

int main(int argc, char *argv[]) {
    /* (a) In dong chao mung dau tien */
    printf("Welcome to IT007, I am <Your_Student_ID>!\n");

    /* Dang ky ham xu ly rieng cho tin hieu SIGINT (Ctrl+C) thay cho
       hanh vi mac dinh la thoat chuong trinh ngay lap tuc            */
    signal(SIGINT, handle_sigint);

    /* (b) Tao tien trinh con de mo tep abcd.txt bang vim */
    child_pid = fork();

    if (child_pid == 0) {
        /* Tien trinh con: thay the hinh anh tien trinh hien tai bang
           chuong trinh vim, mo file abcd.txt de chinh sua             */
        execlp("vim", "vim", "abcd.txt", NULL);

        /* Chi chay den day neu execlp() loi (vd: khong tim thay vim) */
        perror("execlp that bai");
        exit(1);
    } else if (child_pid > 0) {
        /* Tien trinh cha: cho tien trinh con (vim) ket thuc binh
           thuong (vd: nguoi dung tu :wq trong vim). Neu nguoi dung
           nhan Ctrl+C, ham handle_sigint() se duoc goi truoc, tat
           vim va thoat chuong trinh tai do.                          */
        wait(NULL);
        printf("Vim da duoc dong (thoat binh thuong).\n");
    } else {
        perror("fork that bai");
        exit(1);
    }

    return 0;
}

Giai thich logic hoat dong:
1) Chuong trinh in dong chao "Welcome to IT007, I am <MSSV>!" truoc
   tien (yeu cau a).
2) signal(SIGINT, handle_sigint) duoc dang ky de "bat" su kien nguoi
   dung nhan Ctrl+C tai tien trinh cha, thay vi de he thong tu dong
   ket thuc chuong trinh nhu mac dinh.
3) fork() tao tien trinh con; tien trinh con dung execlp() de NAP
   chuong trinh vim va mo file abcd.txt (yeu cau b).
4) Tien trinh cha goi wait(NULL) de cho vim chay; trong luc nay neu
   nguoi dung nhan Ctrl+C tai terminal, tin hieu SIGINT duoc gui den
   tien trinh cha, kich hoat handle_sigint():
   - Ham nay goi kill(child_pid, SIGTERM) de TAT vim (yeu cau c).
   - Sau do in ra "You are pressed CTRL+C! Goodbye!" va thoat chuong
     trinh (yeu cau d).
5) Neu nguoi dung khong nhan Ctrl+C ma tu thoat vim binh thuong (vd
   go :wq), wait(NULL) tra ve nhu thuong va chuong trinh in them
   thong bao da dong vim roi ket thuc tu nhien.
